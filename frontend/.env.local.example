# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to "false" to use Neon DB. Set to "true" to use mock data.
NEXT_PUBLIC_MOCK_MODE=true

# ── Neon DB (Prisma) ──────────────────────────────────────────────────────────
# Paste both connection strings from your Neon project dashboard.
# DATABASE_URL uses the pooled connection (for queries).
# DIRECT_URL uses the direct connection (for migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ── Canton (real mode) ────────────────────────────────────────────────────────
NEXT_PUBLIC_LEDGER_API_URL=http://localhost:7575
LEDGER_API_URL=http://localhost:7575
